# Database (PostgreSQL)
DATABASE_URL="postgres://postgres:PASSWORD@HOST:PORT/dbname?sslmode=disable"

# Origin for OAuth callbacks (e.g. http://localhost:5173 in dev, https://your-domain.com in prod)
ORIGIN="http://localhost:5173"

# Full public site URL for copy-link (e.g. https://kogaionacademy.ro). Falls back to ORIGIN if unset.
PUBLIC_SITE_URL="https://kogaionacademy.ro"

# Better Auth - use 32+ chars in production
BETTER_AUTH_SECRET=""

# Google OAuth (pentru login)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: GA4 Measurement Protocol (server-side), only when user consented to analytics
GA4_MEASUREMENT_ID=""
GA4_API_SECRET=""
