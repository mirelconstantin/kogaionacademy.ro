{
	"name": "kogaion",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:fix-migrations": "bun run scripts/fix-migrations-journal.ts",
		"db:studio": "drizzle-kit studio",
		"db:seed:mentors": "bun run scripts/seed-mentors.ts",
		"db:seed:content": "bun run scripts/seed-content.ts",
		"db:seed:cms": "bun run scripts/seed-cms-defaults.ts",
		"db:seed:sections": "bun run scripts/seed-sections.ts",
		"db:seed:admin": "bun run scripts/seed-admin-request.ts",
		"db:seed:permissions": "bun run scripts/seed-permissions.ts",
		"db:seed:forms": "bun run scripts/seed-forms-default.ts",
		"db:seed:legal": "bun run scripts/seed-legal-policies.ts",
		"db:migrate-to-new": "bun run scripts/migrate-db-to-new.ts",
		"db:ensure-blog-post": "bun run scripts/ensure-blog-post.ts",
		"db:seed:blog-demo": "bun run scripts/seed-blog-demo.ts",
		"db:fix-hero-urls": "bun run scripts/fix-hero-urls.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
