		"formsnap": "^2.0.1",
		"globals": "^17.3.0",
		"mdsvex": "^0.12.6",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"sveltekit-superforms": "^2.28.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
