		"isomorphic-dompurify": "^3.5.1",
		"katex": "^0.16.40",
		"lowlight": "^3.3.0",
		"lucide-svelte": "^0.577.0",
		"marked": "^17.0.5",
		"sharp": "^0.34.5",
		"svelte-dnd-action": "^0.9.69",
		"svelte-sonner": "^1.1.0",
